{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node __LOOM_DIR__/dist/src/hooks/check-path.js"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node __LOOM_DIR__/dist/src/hooks/check-bash.js"
          }
        ]
      }
    ]
  }
}
